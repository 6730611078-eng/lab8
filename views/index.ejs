<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ระบบจัดการคลังสินค้า</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-dark bg-primary mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">Supermarket Admin</a>
    
            <a href="/add" class="btn btn-light btn-sm">+ เพิ่มสินค้าใหม่</a>
        </div>
    </nav>

    <div class="container">
        <h2 class="mb-4">รายการสินค้าทั้งหมด</h2>

        <div class="table-responsive bg-white p-3 rounded shadow-sm">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>รูป</th>
                        <th>ชื่อสินค้า</th>
                        <th>หมวดหมู่</th>
                        <th>ราคา</th>
                        <th>สต็อก</th>
                        <th>จัดการ</th>
                    </tr>
                </thead>
                <tbody>
        
                    <% items.forEach(p => { %>
                    <tr class="align-middle">
                        <td>
            
                            <% if(p.image) { %>
                                <img src="/uploads/<%= p.image %>" width="50" height="50" class="rounded object-fit-cover">
                            <% } else { %>
                                <div class="bg-secondary text-white text-center" style="width:50px; height:50px; line-height:50px; font-size:10px;">No Pic</div>
                            <% } %>
                        </td>
                        <td><strong><%= p.name %></strong></td>
                        <td><%= p.category %></td>
                        <td><%= p.price %> บาท</td>
                        <td>
                            
                            <% if(p.stock <= 0) { %>
                                <span class="badge bg-danger">Out of Stock</span>
                            <% } else { %>
                                <span class="text-success"><%= p.stock %></span>
                            <% } %>
                        </td>
                        <td>
                            <div class="d-flex gap-2">

                                <a href="/edit/<%= p.id %>" class="btn btn-warning btn-sm">แก้ไข</a>
                                

                                <form action="/delete/<%= p.id %>" method="POST" onsubmit="return confirm('จะลบรายการนี้จริงๆ ใช่ไหม?')">
                                    <button type="submit" class="btn btn-danger btn-sm">ลบ</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>